{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables core + sql + fs permissions for the Camog app",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/com.camog.app/**" },
        { "path": "$APPCONFIG/com.camog.app/**" }
      ]
    }
  ]
}
