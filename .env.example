# Camog local configuration.
#
# Copy this file to `.env` (gitignored) and edit. On a fresh database (zero
# users), the app will create the first admin from these credentials
# automatically on startup — no UI button needed. Once any user exists, the
# bootstrap is a no-op.
#
# After changing these, delete the existing SQLite DB (or run Reset & reseed
# on the login screen) to recreate the admin with the new credentials.
#
# Passcodes are stored PBKDF2-hashed (210k iterations, per-user salt). Nothing
# plaintext is written to disk.

NEXT_PUBLIC_CAMOG_BOOTSTRAP_ADMIN_USERNAME=admin
NEXT_PUBLIC_CAMOG_BOOTSTRAP_ADMIN_PASSCODE=devpass123
NEXT_PUBLIC_CAMOG_BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator
# Set to "false" to skip the forced passcode change on first login.
NEXT_PUBLIC_CAMOG_BOOTSTRAP_ADMIN_MUST_CHANGE=false
